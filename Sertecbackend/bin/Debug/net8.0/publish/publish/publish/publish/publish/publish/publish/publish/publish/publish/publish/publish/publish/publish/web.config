<?xml version="1.0" encoding="utf-8"?>
<!--
  IIS deployment configuration for SmarterASP.NET.

  Requirements:
    - ASP.NET Core Hosting Bundle installed on the server (provided by SmarterASP.NET)
    - ASP.NET Core Module V2 (AspNetCoreModuleV2) registered in IIS
    - Application Pool set to "No Managed Code"

  SSE (Server-Sent Events):
    The /api/stream endpoint uses long-lived HTTP connections.
    The <location path="api/stream"> block disables compression and increases
    the connection timeout for that endpoint so IIS does not close idle SSE connections.
-->
<configuration>
  <system.webServer>
    <handlers>
      <!-- Route all requests through the ASP.NET Core in-process module -->
      <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
    </handlers>
    <aspNetCore processPath="dotnet" arguments=".\SertecDashboard.Api.dll" stdoutLogEnabled="true" stdoutLogFile=".\logs\stdout" hostingModel="inprocess">
      <environmentVariables>
        <environmentVariable name="ASPNETCORE_ENVIRONMENT" value="Production" />
      </environmentVariables>
    </aspNetCore>
    <!-- Security headers -->
    <httpProtocol>
      <customHeaders>
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="X-Frame-Options" value="SAMEORIGIN" />
        <add name="X-XSS-Protection" value="1; mode=block" />
        <add name="Referrer-Policy" value="strict-origin-when-cross-origin" />
      </customHeaders>
    </httpProtocol>
    <!-- Disable directory browsing -->
    <directoryBrowse enabled="false" />
    <!-- Hide server version info -->
    <security>
      <requestFiltering removeServerHeader="true">
        <!-- Block requests larger than 52 MB (PDF upload limit) -->
        <requestLimits maxAllowedContentLength="54525952" />
      </requestFiltering>
    </security>
  </system.webServer>
  <!-- Disable compression on the SSE stream so events are flushed immediately -->
  <location path="api/stream">
    <system.webServer>
      <urlCompression doStaticCompression="false" doDynamicCompression="false" />
    </system.webServer>
  </location>
</configuration>
