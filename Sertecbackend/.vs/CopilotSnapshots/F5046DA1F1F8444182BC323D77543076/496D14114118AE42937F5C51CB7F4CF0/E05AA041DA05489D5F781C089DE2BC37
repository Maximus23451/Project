using System.ComponentModel.DataAnnotations;

namespace SertecDashboard.Api.Models;

/// <summary>
/// A production machine tracked in the setter (gépbeállító) dashboard.
/// Each machine has a list of parts (checklist items).
/// </summary>
public class Machine
{
    [Key]
    public int Id { get; set; }

    [Required]
    [MaxLength(100)]
    public string Name { get; set; } = string.Empty;

    /// <summary>Navigation property — checklist parts for this machine.</summary>
    public List<MachinePart> MachineParts { get; set; } = new();
}
