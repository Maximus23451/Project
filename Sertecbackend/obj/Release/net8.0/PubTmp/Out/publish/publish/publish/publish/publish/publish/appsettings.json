{
  // ── Base configuration (safe to commit) ─────────────────────────
  // Sensitive production values (connection string, SMTP) go in
  // appsettings.Production.json which is NEVER committed to source control.

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },

  // Comma-separated list of allowed CORS origins.
  // In production, set this to your exact domain (e.g. "https://yourdomain.smarterasp.net")
  "AllowedOrigins": "http://localhost:5173",

  // Local dev connection string — OVERRIDE in appsettings.Production.json for Somee.com
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=SertecDashboard;Trusted_Connection=True;TrustServerCertificate=True;"
  },

  // Optional SMTP email notifications for missed alerts / password resets
  // Leave empty to disable email (app works fine without it)
  "Smtp": {
    "Host": "",
    "Port": 587,
    "User": "",
    "Pass": "",
    "From": "sertec@gyar.hu"
  }
}
